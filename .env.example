# copy to .env on the lxn host and fill in real values.
# listen_lxn_mqtt will not start without these.

# MQTT broker (the lxn host itself, or wherever mosquitto lives)
MQTT_HOST=lxn
MQTT_TOPIC=sensors/#

# PostgreSQL on lxn (matches pg_lxn_esp/ defaults)
PG_HOST=127.0.0.1
PG_PORT=5432
PG_USER=lxn
PG_PASSWORD=changeme
PG_DB=lxn
